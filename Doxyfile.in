PROJECT_NAME           = @PROJECT_NAME@
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/docs
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/include @CMAKE_CURRENT_SOURCE_DIR@/src
RECURSIVE              = YES
EXTRACT_ALL            = YES
FILE_PATTERNS          = *.hpp *.cpp
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
HAVE_DOT               = NO
